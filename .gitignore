## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Blazor build outputs
wwwroot/_framework/
wwwroot/css/
wwwroot/js/
wwwroot/*.gz
wwwroot/*.br

# Uncomment if you have tasks that create the project's static assets at runtime
# wwwroot/

# Visual Studio 2019/2022 cache/options
.vs/
.vscode/

# Rider
.idea/
*.sln.iml

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Visual Studio database files
*.mdf
*.ldf

# Others
*.dbmdl
*.bak
*.backup
*.log
*.tlog
*.cache
*.pdb
*.opendb
*.tmp

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
!**/packages/build/
# Uncomment if necessary
#!**/packages/repositories.config

# Microsoft Azure Web App publish settings
*.PublishSettings
*.pubxml
*.pubxml.user

# User-specific files for Visual Studio Code
.history/
.vscode/*

# Local environment files
.env
.env.*

# Mac
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# JetBrains Rider
.idea/
*.sln.iml

# Node modules (if you use npm for Blazor WebAssembly)
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# Coverage
coverage/
*.coverage
*.coveragexml

# Generated documentation
docfx/_site/

# Temporary files
*.swp
*.swo

